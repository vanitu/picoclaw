# PicoClaw Docker Environment Configuration
# Copy this file to .env and customize as needed

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Optional: Override default ports
# GATEWAY_PORT=8080
# LAUNCHER_PORT=3000

# Optional: OpenAI/Claude API keys (if not in config.json)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# Optional: Telegram bot token (if using Telegram channel)
# TELEGRAM_BOT_TOKEN=...

# Optional: Discord bot token (if using Discord channel)
# DISCORD_BOT_TOKEN=...
