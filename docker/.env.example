# PicoClaw Docker Environment Configuration
# Copy this file to .env and customize as needed

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Gateway port - all channels share this single port
# Default is 18790, configure via gateway.port in config.json
# GATEWAY_PORT=18790

# Optional: OpenAI/Claude API keys (if not in config.json)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# Optional: Telegram bot token (if using Telegram channel)
# TELEGRAM_BOT_TOKEN=...

# Optional: Discord bot token (if using Discord channel)
# DISCORD_BOT_TOKEN=...
