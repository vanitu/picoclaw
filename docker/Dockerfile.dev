# PicoClaw - Development Docker Image
# Builds from source code for local development/testing
# Usage: docker build -f docker/Dockerfile.dev -t picoclaw:dev .

# Build stage
FROM golang:1.24-alpine AS builder

# Enable toolchain to auto-download required Go version
ENV GOTOOLCHAIN=auto

# Install build dependencies
RUN apk add --no-cache \
    git \
    make \
    nodejs \
    npm

# Install pnpm for frontend builds
RUN npm install -g pnpm

# Set working directory
WORKDIR /build

# Copy go mod files first for better caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build the binary
RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w" \
    -o picoclaw \
    ./cmd/picoclaw

# Runtime stage
FROM alpine:3.21

# Install runtime dependencies
RUN apk add --no-cache \
    ca-certificates \
    tzdata \
    wget

# Create non-root user
RUN adduser -D -s /bin/sh picoclaw

# Copy binary from builder
COPY --from=builder /build/picoclaw /usr/local/bin/picoclaw

# Copy entrypoint script
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create data and config directories
RUN mkdir -p /data /config && \
    chown -R picoclaw:picoclaw /data /config

# Switch to non-root user
USER picoclaw

# Expose volumes for persistence
VOLUME ["/data", "/config"]
WORKDIR /data

# Gateway port - all webhook channels (Krabot, A2A, LINE, WeCom, etc.) 
# share this single port, routed by path:
#   /krabot/*    - Krabot WebSocket channel
#   /a2a/*       - A2A protocol endpoints
#   /.well-known/agent.json - A2A agent discovery
#   /health      - Health endpoint
# Default is 18790, but expose common alternatives
EXPOSE 18790 8080

# Health check (adjust port if you change gateway.port in config)
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD wget -q --spider http://localhost:18790/health 2>/dev/null || wget -q --spider http://localhost:8080/health 2>/dev/null || exit 1

# Entrypoint handles initialization
ENTRYPOINT ["/entrypoint.sh"]

# Default command: run gateway
CMD ["picoclaw", "gateway"]
